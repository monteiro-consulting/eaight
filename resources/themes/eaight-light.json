{
  "$schema": "./schema.json",
  "name": "eaight Light",
  "type": "light",
  "colors": {
    "background": {
      "primary": "#ffffff",
      "secondary": "#fceade",
      "tertiary": "#f5f5f5"
    },
    "foreground": {
      "primary": "#1a1a2e",
      "secondary": "#6b7280",
      "muted": "#9ca3af"
    },
    "accent": {
      "primary": "#25ced1",
      "secondary": "#ea526f",
      "tertiary": "#ff8a5b",
      "success": "#4ade80",
      "warning": "#facc15",
      "error": "#ef4444",
      "info": "#25ced1"
    },
    "border": {
      "default": "#e5e7eb",
      "focus": "#25ced1"
    }
  },
  "fonts": {
    "family": "-apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
    "sizeBase": 14,
    "sizeSmall": 12,
    "sizeLarge": 16
  },
  "spacing": {
    "unit": 4
  },
  "borderRadius": {
    "small": 4,
    "medium": 8,
    "large": 12
  }
}
